# NexaFlow Backend — Environment Variables
# Copy to .env and customize

APP_NAME=NexaFlow
APP_VERSION=1.0.0
DEBUG=false

# CHANGE THIS in production — use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=nexaflow-dev-secret-key-change-in-production

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./nexaflow.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/nexaflow

# Analysis limits
MAX_FILE_SIZE_KB=500
MAX_FILES_PER_REVIEW=20
